# Supabase: project URL + anon key (NUXT_PUBLIC_ = exposed client-side)
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase: JWT secret key for server-side token signing (NOT prefixed with NUXT_PUBLIC_)
NUXT_SUPABASE_SECRET_KEY=your-jwt-secret

# Supabase: direct Postgres connection string (for Drizzle migrations, NOT for the app runtime)
# Get this from Supabase Dashboard → Project Settings → Database → Connection string → URI
NUXT_SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Razorpay (Phase 2)
NUXT_PUBLIC_RAZORPAY_KEY_ID=
NUXT_RAZORPAY_KEY_SECRET=

# SMS (Phase 4)
MSG91_API_KEY=

# Email (Phase 4)
NUXT_RESEND_API_KEY=

# Firebase (Phase 4)
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Sentry (Phase 6)
NUXT_SENTRY_DSN=
